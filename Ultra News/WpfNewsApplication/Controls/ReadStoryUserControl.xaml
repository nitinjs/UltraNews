<UserControl x:Class="Nitin.News.Controls.ReadStoryUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Nitin.News.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="500">
    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Height="120" Background="WhiteSmoke" Orientation="Vertical">
            <Image Source="../Resources/Images/cooltext819042054.png" Width="300"></Image>
            <TextBlock FontSize="13" TextAlignment="Center">Geo-location enabled news reader application</TextBlock>
            <Separator></Separator>
            <DockPanel>
                <Button DockPanel.Dock="Left" Name="btnBack" Padding="3" Margin="5,5" Click="btnBack_Click">&lt;&lt; Back</Button>
                <Label DockPanel.Dock="Left" FontWeight="SemiBold" FontSize="15" HorizontalAlignment="Left">Location:
                </Label>
                <Label Name="lblLocation" DockPanel.Dock="Left" FontSize="15" HorizontalAlignment="Left">Mumbai, IN
                </Label>
                <Label Name="lblDateTime" DockPanel.Dock="Right" FontWeight="Normal" FontSize="15" HorizontalAlignment="Right"></Label>
                <Label DockPanel.Dock="Right" FontWeight="SemiBold" FontSize="15" HorizontalAlignment="Right"></Label>
            </DockPanel>
            <Border BorderThickness="0,2,0,1" Margin="0,3,0,5">
                <Border.BorderBrush>
                    <SolidColorBrush Color="Gray"></SolidColorBrush>
                </Border.BorderBrush>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Color="Gray" Direction="1" Opacity=".3"
           RenderingBias="Quality" ShadowDepth="5" />
                </Border.Effect>
                <Separator></Separator>
            </Border>
        </StackPanel>
