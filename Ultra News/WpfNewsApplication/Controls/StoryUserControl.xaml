<UserControl x:Class="Nitin.News.Controls.StoryUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Nitin.News.Controls"
             mc:Ignorable="d" TouchDown="UserControl_TouchDown">
    <UserControl.Style>
        <Style>
            <Setter Property="local:StoryUserControl.BorderThickness" Value="1"></Setter>
            <Setter Property="local:StoryUserControl.Background" Value="White"></Setter>
            <Setter Property="local:StoryUserControl.BorderBrush" Value="Transparent"></Setter>
            <Setter Property="local:StoryUserControl.Padding" Value="0"></Setter>
            <Setter Property="local:StoryUserControl.Margin" Value="0"></Setter>
            <Setter Property="local:StoryUserControl.Focusable" Value="True"></Setter>
        </Style>
    </UserControl.Style>
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!--<ResourceDictionary Source="/Themes/MyTheme.xaml"/>-->
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Border Name="brdMain" Margin="0,0,0,0" BorderThickness="0,0,0,0" BorderBrush="Gray" CornerRadius="0" Padding="6,5,6,3"
        HorizontalAlignment="Left" VerticalAlignment="Top" Focusable="False">
        <Border.FocusVisualStyle>
            <Style>

            </Style>
        </Border.FocusVisualStyle>
