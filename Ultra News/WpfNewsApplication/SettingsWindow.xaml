<Window x:Class="Nitin.News.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ultra News - Settings" Width="340.338" Height="185.188" ShowInTaskbar="False" WindowState="Normal" WindowStartupLocation="CenterScreen" WindowStyle="ThreeDBorderWindow" Icon="Newspaper-Feed.ico">
    <StackPanel Orientation="Vertical" Margin="5">
        <TextBlock Margin="3">Location:</TextBlock>
        <RadioButton Name="rbInbuilt" Margin="3" GroupName="Location" IsChecked="True" Checked="rbInbuilt_Checked">Use Inbuilt GPS</RadioButton>
        <RadioButton Name="rbManual" Margin="3" Checked="rbInbuilt_Checked" GroupName="Location">Manual </RadioButton>
        <StackPanel Orientation="Horizontal">
            <TextBlock Name="txtEnter" Margin="5">Enter Location-
            </TextBlock>
            <TextBox Margin="5" Name="txtLocation" Width="100"></TextBox>
            <TextBlock Margin="5">e.g. New York, USA</TextBlock>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Margin="5" HorizontalAlignment="Center">
            <Button HorizontalAlignment="Center" Name="btnOk" Padding="5" Margin="0,0,5,0" Click="btnOk_Click">Ok</Button>
            <Button HorizontalAlignment="Center" Name="btnDefault" Padding="5" Margin="0,0,5,0" Click="btnDefault_Click">Default</Button>
            <Button HorizontalAlignment="Center" Name="btnCancel" Padding="5" Click="btnCancel_Click">Cancel</Button>
        </StackPanel>
    </StackPanel>
</Window>
