<Window x:Class="Nitin.News.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:local="clr-namespace:Nitin.News.Controls"
		xmlns:pageTransitions="clr-namespace:WpfPageTransitions;assembly=WpfPageTransitions"
        Title="Ultra News - A geolocation, touch enabled ultrabook news reader application powered by Feedzilla"        
        WindowState="Maximized" 
        WindowStyle="SingleBorderWindow"
        Width="620"
        Icon="Newspaper-Feed.ico"
        Height="440"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="Resources/Images/clock_icon_48.png" Stretch="None" TileMode="None" AlignmentX="Center" AlignmentY="Center" Opacity="0.53"></ImageBrush>
        </Grid.Background> 
        <pageTransitions:PageTransition Name="pageTransitionControl" TransitionType="SlideAndFade"/>
    </Grid>
</Window>
